<div style="width: @Size; height: @Size; border-radius: 50%; overflow: hidden; border: 2px; position: relative; display: inline-block;">
    <svg viewBox="0 0 200 200" style="width: 100%; height: 100%;">
        @* Циферблат *@
        <circle cx="100" cy="100" r="95" stroke-width="4" fill="@BackgroundColor" stroke="@BorderColor" />
        <image href="@ImageBase64" x="0" y="0" width="@SizeImage" height="@SizeImage" style=" object-fit: cover; transform: rotate(180deg); transform-origin: center;" />
        
        @* Метки *@
        @for (int i = 0; i < TickCount + 1 && bDrowTick; i++)
        {
            var angle = i * (EndAngel / TickCount) - StartAngle;
            var rad = angle * Math.PI / 180;
            var x1 = 100 + 80 * Math.Cos(rad);
            var y1 = 100 + 80 * Math.Sin(rad);
            var x2 = 100 + 90 * Math.Cos(rad);
            var y2 = 100 + 90 * Math.Sin(rad);

            <line x1="@x1" y1="@y1" x2="@x2" y2="@y2" stroke="@TickColor" stroke-width="3" />
        }

        @* Стрелка *@
        @{
            var percentage = Math.Clamp((double)(Value - MinValue) / (MaxValue - MinValue), 0, 1);
            var valueAngle = percentage * EndAngel - StartAngle;
            var valueRad = valueAngle * Math.PI / 180;
            var valueX = 100 + 75 * Math.Cos(valueRad);
            var valueY = 100 + 75 * Math.Sin(valueRad);
        }
        <line x1="100" y1="100" x2="@valueX" y2="@valueY" 
        stroke="@NeedleColor" stroke-width="4" stroke-linecap="round" />

        @* Центр *@
        <circle cx="100" cy="100" r="8" fill="@NeedleColor" />
    </svg>

    @* Значение в центре *@
    <div style="position: absolute; bottom: @PosTextY%; left: @PosTextX%; transform: translateX(-50%); text-align: center;">
        @{
            var textStyle = $"color: {TextColor}; font-weight: bold; line-height: 1;";
        }
        <MudText Typo="@TextTypo" Style="@textStyle">@Value.ToString(Format)</MudText>

        @if (!string.IsNullOrEmpty(Text))
        {
            var unitStyle = $"color: {TextColor};";
            <MudText Typo="Typo.caption" Style="@unitStyle">@Text</MudText>
        }
    </div>
</div>

@code {
    /// <summary>
    /// Значение double для отображения на циферблате и стрелки
    /// </summary>
    [Parameter] public double Value { get; set; }

    /// <summary>
    /// Минимальное значение для стрелки
    /// </summary>
    /// <remarks>
    /// Default = 0
    /// </remarks>
    [Parameter] public double MinValue { get; set; } = 0;

    /// <summary>
    /// Максимальное значение для стрелки
    /// </summary>
    /// <remarks>
    /// Default = 100
    /// </remarks>
    [Parameter] public double MaxValue { get; set; } = 100;

    /// <summary>
    /// Текст под значением value
    /// </summary>
    /// <remarks>
    /// Default = ""
    /// </remarks>
    [Parameter] public string Text { get; set; } = "";

    /// <summary>
    /// Количество цифр после запетой в формате F0 - F1 - F2 - F3
    /// </summary>
    /// <remarks>
    /// <para>Default = "F0"</para>
    /// <para>Min -> F0 || Max -> F3</para>
    /// </remarks>
    [Parameter] public string Format { get; set; } = "F0";

    /// <summary>
    /// Конечный угол для отображения рисок на круге и конечная позиция для стрелки
    /// </summary>
    /// <remarks>
    /// <para>Default = 360</para>
    /// </remarks>
    [Parameter] public int EndAngel { get; set; } = 360;

    /// <summary>
    /// Стартовый угол для отображения рисок на круге и стартовая позиция для стрелки
    /// </summary>
    /// <remarks>
    /// <para>Default = 90</para>
    /// </remarks>
    [Parameter] public int StartAngle { get; set; } = 90;

    /// <summary>
    /// Размер всего циферблата
    /// </summary>
    /// <remarks>
    /// <para>Default = "200px"</para>
    /// <para>Принимает или px или %</para>
    /// </remarks>
    [Parameter] public string Size { get; set; } = "200px";

    /// <summary>
    /// Количество рисок на циферблате
    /// </summary>
    /// <remarks>
    /// <para>Default = 12</para>
    /// </remarks>
    [Parameter] public int TickCount { get; set; } = 12; 

    /// <summary>
    /// Цвет фона циферблата в hex формате
    /// </summary>
    /// <remarks>
    /// <para>Default = "#1a1a1a" (серый)</para>
    /// </remarks>
    [Parameter] public string BackgroundColor { get; set; } = "#1a1a1a";

    /// <summary>
    /// Цвет границы/обода циферблата в hex формате
    /// </summary>
    /// <remarks>
    /// <para>Default = "#333333" (светло серый)</para>
    /// </remarks>
    [Parameter] public string BorderColor { get; set; } = "#333333";

    /// <summary>
    /// Цвет рисок циферблата в hex формате
    /// </summary>
    /// <remarks>
    /// <para>Default = "#ffffff" (белый)</para>
    /// </remarks>
    [Parameter] public string TickColor { get; set; } = "#ffffff";

    /// <summary>
    /// Цвет стрелки циферблата в hex формате
    /// </summary>
    /// <remarks>
    /// <para>Default = "#ff4444" (красный)</para>
    /// </remarks>
    [Parameter] public string NeedleColor { get; set; } = "#ff4444";

    /// <summary>
    /// Цвет текста циферблата в hex формате
    /// </summary>
    /// <remarks>
    /// <para>Default = "#ffffff" (белый)</para>
    /// </remarks>
    [Parameter] public string TextColor { get; set; } = "#ffffff";

    /// <summary>
    /// Тип выводимого текста через MudBlazor.Typo
    /// </summary>
    /// <remarks>
    /// <para>Default = Typo.h4</para>
    /// </remarks>
    [Parameter] public MudBlazor.Typo TextTypo { get; set; } = Typo.h4;

    /// <summary>
    /// Позиция текста по Y (высоте)
    /// </summary>
    /// <remarks>
    /// <para>Не относительно центра!!!!</para>
    /// <para>Default = 30</para>
    /// </remarks>
    [Parameter] public int PosTextY { get; set; } = 30;

    /// <summary>
    /// Позиция текста по X (ширине)
    /// </summary>
    /// <remarks>
    /// <para>Не относительно центра!!!!</para>
    /// <para>Default = 50</para>
    /// </remarks>
    [Parameter] public int PosTextX { get; set; } = 50;

    /// <summary>
    /// Размер картинки относительно циферблата
    /// </summary>
    /// <remarks>
    /// <para>Default = "100%"</para>
    /// </remarks>
    [Parameter] public string SizeImage { get; set; } = "100%";

    /// <summary>
    /// Картинка в формате Base64
    /// </summary>
    /// <remarks>
    /// <para>Default = "100%"</para>
    /// </remarks>
    [Parameter] public string ImageBase64 { get; set; }

    /// <summary>
    /// Параметр для создания рисок на циферблате
    /// </summary>
    /// <remarks>
    /// <para>Default = bool true</para>
    /// </remarks>
    [Parameter] public bool bDrowTick { get; set; } = true;

}
