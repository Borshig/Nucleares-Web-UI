@page "/core"
@rendermode InteractiveServer
@implements IDisposable

<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<PageTitle>Home</PageTitle>

<MudPaper Class="pa-4">
    @if (isLoading)
    {
        <MudProgressCircular Color="Color.Success" Indeterminate="isLoading" Size="Size.Small" />
        <MudText Typo="Typo.caption" Class="ml-2">Ожидание данных от веб сервера...</MudText>
    }
    <MudText Typo="Typo.h5" Align="Align.Center" Class="mt-16">Температура стержней реактора</MudText>
    <MudChart ChartType="ChartType.HeatMap" ChartSeries="@_seriesСoreTemp" ChartOption="@_option"
     ChartLabels = "@_xlabels" Width="100%" Height="280px"></MudChart>
</MudPaper>

<MudPaper Class="pa-4">
    <MudText Typo="Typo.h5" Align="Align.Center" Class="mt-16">Позиция стержней реактора</MudText>
    <MudChart ChartType="ChartType.HeatMap" ChartSeries="@_seriesPosBank" ChartOption="@_option"
     ChartLabels="@_xlabels" Width="100%" Height="280px"></MudChart>
</MudPaper>

@code {
    private bool isLoading = true;
    private static string[] colors = ["#FFFFFF","#00BFFF","#5AC8FA", "#34C759", "#007AFF", "#FFCC00", "#e03131"];
    private ChartOptions _option = new ChartOptions{ChartPalette = colors};
    private string[] _xlabels = [];
    private List<ChartSeries<double>> _seriesСoreTemp = new List<ChartSeries<double>>();
    private List<ChartSeries<double>> _seriesPosBank = new List<ChartSeries<double>>();

    private CancellationTokenSource _cts = new();

    protected override void OnInitialized()
    {
        // Запускаем фоновую задачу без ожидания (fire-and-forget)
        _ = BackgroundLoop(_cts.Token);
    }

    private async Task BackgroundLoop(CancellationToken ct)
    {
        try
        {
            while (!ct.IsCancellationRequested)
            {

                HeatMapDataSet();

                // Обязательно уведомляем UI об изменениях
                await InvokeAsync(StateHasChanged);

                // Задержка, чтобы не вешать поток
                await Task.Delay(1000, ct);
            }
        }
        catch (TaskCanceledException)
        {
            // Нормальное завершение при закрытии страницы
        }
    }

    // Остановка цикла при уничтожении компонента
    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }

    public void HeatMapDataSet()
    {
        var data = new Dictionary<string, string>();
        data = NuclearesGETData.Programs.Second();

        if (data.Count == 0)
        {
            isLoading = true;
            return;
        }

        isLoading = false;

        string[] rodBankPos = ["ROD_BANK_POS_0_ACTUAL", "ROD_BANK_POS_1_ACTUAL", "ROD_BANK_POS_2_ACTUAL", "ROD_BANK_POS_3_ACTUAL", "ROD_BANK_POS_4_ACTUAL", "ROD_BANK_POS_5_ACTUAL", "ROD_BANK_POS_6_ACTUAL", "ROD_BANK_POS_7_ACTUAL", "ROD_BANK_POS_8_ACTUAL"];
        string[] coreTemp = ["CORE_FUEL_1_TEMPERATURE","CORE_FUEL_2_TEMPERATURE","CORE_FUEL_3_TEMPERATURE","CORE_FUEL_4_TEMPERATURE","CORE_FUEL_5_TEMPERATURE","CORE_FUEL_6_TEMPERATURE","CORE_FUEL_7_TEMPERATURE","CORE_FUEL_8_TEMPERATURE","CORE_FUEL_9_TEMPERATURE",];
        //string[] xaxis2 = ["ROD 1", "ROD 2", "ROD 3", "ROD 4", "ROD 5", "ROD 6", "ROD 7", "ROD 8", "ROD 9"];
        string[] xAxis = [string.Empty, string.Empty, string.Empty];

        var heatMapSeriesCoreTemp = new List<ChartSeries<double>>();
        var heatMapSeriesPosBank = new List<ChartSeries<double>>();
        var dataPoints = 3;
        var dataCoreTemp = new double[dataPoints];
        var dataBankPos = new double[dataPoints];
        int[] indexPos =
        [8,1,2,
         7,0,3,
         6,5,4];
        int index, im = 0;

        foreach (var x in xAxis)
        {
            for (int i = 0; i < 3; i++)
            {
                index = indexPos[im];
                im++;

                if (data[rodBankPos[index]] != "null")
                {
                    dataBankPos[i] = Math.Round(Convert.ToDouble(data[rodBankPos[index]]), 2);
                }
                else
                {
                    dataBankPos[i] = 0f;
                    dataCoreTemp[i] = 0f;
                }
                dataCoreTemp[i] = Math.Round(Convert.ToDouble(data[coreTemp[index]]), 2);
            }
            heatMapSeriesCoreTemp.Add(new ChartSeries<double> { Name = x, Data = dataCoreTemp });
            heatMapSeriesPosBank.Add(new ChartSeries<double> { Name = x, Data = dataBankPos });
        } //"Температура Стержней""Позиция стержней"
        _xlabels = xAxis;
        _seriesСoreTemp = heatMapSeriesCoreTemp;
        _seriesPosBank = heatMapSeriesPosBank;
    }

}