@page "/TestPage3"
@rendermode InteractiveServer

<MudPopoverProvider />

<h3>WIP</h3>
<MudMenu Label="Menu">
    <MudMenuItem Label="Home" Href="/" />
    <MudMenuItem Label="Core" Href="/core" />
    <MudMenuItem Label="WIP" Href="/WIP" />
</MudMenu>
<MudButton Color="Color.Primary" Variant="Variant.Filled" @onclick="valueCount">Click me</MudButton>

<div style="width: 250px; height: 250px; position: relative;">
    <svg viewBox="0 0 200 200" style="width: 100%; height: 100%;">
        <circle cx="100" cy="100" r="95" fill="#1a1a1a" stroke="#333" stroke-width="4" />

        @for (int i = 0; i < 12; i++)
        {
            var angle = i * 17 - 180;
            var rad = angle * Math.PI / 180;
            var x1 = 100 + 80 * Math.Cos(rad);
            var y1 = 100 + 80 * Math.Sin(rad);
            var x2 = 100 + 90 * Math.Cos(rad);
            var y2 = 100 + 90 * Math.Sin(rad);

            <line x1="@x1" y1="@y1" x2="@x2" y2="@y2" stroke="#fff" stroke-width="3" />
        }

        @{
            var valueAngle = (GetPercentage() * 180) - 180;
            var valueRad = valueAngle * Math.PI / 180;
            var valueX = 100 + 75 * Math.Cos(valueRad);
            var valueY = 100 + 75 * Math.Sin(valueRad);
        }
        <line x1="100" y1="100" x2="@valueX" y2="@valueY"
              stroke="#ff4444" stroke-width="4" stroke-linecap="round" />

        <circle cx="100" cy="100" r="8" fill="#ff4444" />
    </svg>

    <div style="position: absolute; bottom: 30%; left: 50%; transform: translateX(-50%);">
        <MudText Typo="Typo.h4" Style="color: white; font-weight: bold;">@_value</MudText>
    </div>
</div>

@code {
    private int _value = 0;
    private void valueCount()
    {
        _value += 1;
    }
    private int _maxValue = 100;

    private double GetPercentage() => (double)_value / _maxValue;
}