@page "/energyProduction"
@rendermode InteractiveServer

@if (isLoading)
{
    <MudProgressCircular Color="Color.Success" Indeterminate="isLoading" Size="Size.Small" />
    <MudText Typo="Typo.caption" Class="ml-2">Ожидание данных от веб сервера...</MudText>
}

<MudGrid Spacing="3">
    <MudItem xs="2">
        <MudPaper Class="d-flex align-center justify-center py-4" style="background-color: darkred" >
            <SevenSegmentDisplay Digits="4" Value="@gen1W" SegmentOffColor="#3e3d42" SegmentColor="#F9F9F9"></SevenSegmentDisplay>
        </MudPaper>
        <MudPaper Class="d-flex align-center justify-center py-4" style="background-color: black" >
            <SevenSegmentDisplay Digits="4" Value="@gen1RPM" SegmentOffColor="#3e3d42" SegmentColor="#F9F9F9"></SevenSegmentDisplay>
        </MudPaper>
        <MudPaper Class="d-flex align-center justify-center py-4" style="background-color: darkgreen">
            <SevenSegmentDisplay Digits="5" Value="@gen1V" SegmentOffColor="#3e3d42" SegmentColor="#F9F9F9"></SevenSegmentDisplay>
        </MudPaper>
        <MudPaper Class="d-flex align-center justify-center py-4" style="background-color: darkblue">
            <SevenSegmentDisplay Digits="3" Value="@gen1Hz" SegmentOffColor="#3e3d42" SegmentColor="#F9F9F9"></SevenSegmentDisplay>
        </MudPaper>
        <MudPaper Class="d-flex align-center justify-center py-4" style="background-color: black" >
            <SevenSegmentDisplay Digits="5" Value="@gen1A" SegmentOffColor="#3e3d42" SegmentColor="#F9F9F9"></SevenSegmentDisplay>
        </MudPaper>
    </MudItem>
    <MudItem xs="2">
        <MudPaper Class="d-flex align-center justify-center py-4" style="background-color: darkred">
            <SevenSegmentDisplay Digits="4" Value="@gen2W" SegmentOffColor="#3e3d42" SegmentColor="#F9F9F9"></SevenSegmentDisplay>
        </MudPaper>
        <MudPaper Class="d-flex align-center justify-center py-4" style="background-color: black" >
            <SevenSegmentDisplay Digits="4" Value="@gen2RPM" SegmentOffColor="#3e3d42" SegmentColor="#F9F9F9"></SevenSegmentDisplay>
        </MudPaper>
        <MudPaper Class="d-flex align-center justify-center py-4" style="background-color: darkgreen">
            <SevenSegmentDisplay Digits="5" Value="@gen2V" SegmentOffColor="#3e3d42" SegmentColor="#F9F9F9"></SevenSegmentDisplay>
        </MudPaper>
        <MudPaper Class="d-flex align-center justify-center py-4" style="background-color: darkblue">
            <SevenSegmentDisplay Digits="3" Value="@gen2Hz" SegmentOffColor="#3e3d42" SegmentColor="#F9F9F9"></SevenSegmentDisplay>
        </MudPaper>
        <MudPaper Class="d-flex align-center justify-center py-4" style="background-color: black" >
            <SevenSegmentDisplay Digits="5" Value="@gen2A" SegmentOffColor="#3e3d42" SegmentColor="#F9F9F9"></SevenSegmentDisplay>
        </MudPaper>
    </MudItem>
    <MudItem xs="2">
        <MudPaper Class="d-flex align-center justify-center py-4" style="background-color: darkred">
            <SevenSegmentDisplay Digits="4" Value="@gen3W" SegmentOffColor="#3e3d42" SegmentColor="#F9F9F9"></SevenSegmentDisplay>
        </MudPaper>
        <MudPaper Class="d-flex align-center justify-center py-4" style="background-color: black" >
            <SevenSegmentDisplay Digits="4" Value="@gen3RPM" SegmentOffColor="#3e3d42" SegmentColor="#F9F9F9"></SevenSegmentDisplay>
        </MudPaper>
        <MudPaper Class="d-flex align-center justify-center py-4" style="background-color: darkgreen">
            <SevenSegmentDisplay Digits="5" Value="@gen3V" SegmentOffColor="#3e3d42" SegmentColor="#F9F9F9"></SevenSegmentDisplay>
        </MudPaper>
        <MudPaper Class="d-flex align-center justify-center py-4" style="background-color: darkblue">
            <SevenSegmentDisplay Digits="3" Value="@gen3Hz" SegmentOffColor="#3e3d42" SegmentColor="#F9F9F9"></SevenSegmentDisplay>
        </MudPaper>
        <MudPaper Class="d-flex align-center justify-center py-4" style="background-color: black" >
            <SevenSegmentDisplay Digits="5" Value="@gen3A" SegmentOffColor="#3e3d42" SegmentColor="#F9F9F9"></SevenSegmentDisplay>
        </MudPaper>
    </MudItem>
    <MudItem xs="2">
        <MudPaper Class="d-flex align-center justify-center py-4" style="background-color: darkred">
            <SevenSegmentDisplay Digits="4" Value="@busW" SegmentOffColor="#3e3d42" SegmentColor="#F9F9F9"></SevenSegmentDisplay>
        </MudPaper>
        <MudPaper Class="d-flex align-center justify-center py-4" style="background-color: black">
            <SevenSegmentDisplay Digits="4" Value="@busRPM" SegmentOffColor="#3e3d42" SegmentColor="#F9F9F9"></SevenSegmentDisplay>
        </MudPaper>
        <MudPaper Class="d-flex align-center justify-center py-4" style="background-color: darkgreen">
            <SevenSegmentDisplay Digits="5" Value="@busV" SegmentOffColor="#3e3d42" SegmentColor="#F9F9F9"></SevenSegmentDisplay>
        </MudPaper>
        <MudPaper Class="d-flex align-center justify-center py-4" style="background-color: darkblue">
            <SevenSegmentDisplay Digits="3" Value="@busHz" SegmentOffColor="#3e3d42" SegmentColor="#F9F9F9"></SevenSegmentDisplay>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private bool isLoading = true;

    private string gen1W = "";
    private string gen2W = "";
    private string gen3W = "";
    private string gen1RPM = "";
    private string gen2RPM = "";
    private string gen3RPM = "";
    private string gen1V = "";
    private string gen2V = "";
    private string gen3V = "";
    private string gen1Hz = "";
    private string gen2Hz = "";
    private string gen3Hz = "";
    private string gen1A = "";
    private string gen2A = "";
    private string gen3A = "";

    private string busW = "";
    private string busRPM = "0000";
    private string busV = "22000";
    private string busHz = "50";

    private CancellationTokenSource _cts = new();

    protected override void OnInitialized()
    {
        // Запускаем фоновую задачу без ожидания (fire-and-forget)
        _ = BackgroundLoop(_cts.Token);
        DataSetDisplay();
    }

    private async Task BackgroundLoop(CancellationToken ct)
    {
        try
        {
            while (!ct.IsCancellationRequested)
            {
                DataSetDisplay();
                // Обязательно уведомляем UI об изменениях
                await InvokeAsync(StateHasChanged);

                // Задержка, чтобы не вешать поток
                await Task.Delay(1000, ct);
            }
        }
        catch (TaskCanceledException)
        {
            // Нормальное завершение при закрытии страницы
        }
    }

    // Остановка цикла при уничтожении компонента
    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }

    public async void DataSetDisplay()
    {
        var data = new Dictionary<string, string>();
        data = await NuclearesGETData.Programs.Second();

        if (data.Count == 0)
        {
            isLoading = true;
            return;
        }
        isLoading = false;

        int igen1W = Convert.ToInt32(data["GENERATOR_0_KW"]);
        int igen2W = Convert.ToInt32(data["GENERATOR_1_KW"]);
        int igen3W = (int)Math.Round(Convert.ToDouble(data["GENERATOR_2_KW"]));
        int igen1Hz = (int)Math.Round(Convert.ToDouble(data["GENERATOR_0_HERTZ"]));
        int igen2Hz = (int)Math.Round(Convert.ToDouble(data["GENERATOR_1_HERTZ"]));
        int igen3Hz = (int)Math.Round(Convert.ToDouble(data["GENERATOR_2_HERTZ"])); 
        int igen1A = (int)Math.Round(Convert.ToDouble(data["GENERATOR_0_A"]));
        int igen2A = (int)Math.Round(Convert.ToDouble(data["GENERATOR_1_A"]));
        int igen3A = (int)Math.Round(Convert.ToDouble(data["GENERATOR_2_A"]));
        //int busRPM;
        //int busV;
        //int busHz;

        gen1W = igen1W.ToString().Length <= 4 ? Convert.ToString(igen1W) : Convert.ToString(igen1W / 1000);
        gen2W = igen2W.ToString().Length <= 4 ? Convert.ToString(igen2W) : Convert.ToString(igen2W / 1000);
        gen3W = igen3W.ToString().Length <= 4 ? Convert.ToString(igen3W) : Convert.ToString(igen3W / 1000);
        gen1RPM = data["STEAM_TURBINE_0_RPM"];
        gen2RPM = data["STEAM_TURBINE_1_RPM"];
        gen3RPM = data["STEAM_TURBINE_2_RPM"];
        gen1V = data["GENERATOR_0_V"];
        gen2V = data["GENERATOR_1_V"];
        gen3V = data["GENERATOR_2_V"];
        gen1Hz = Convert.ToString(igen1Hz);
        gen2Hz = Convert.ToString(igen2Hz);
        gen3Hz = Convert.ToString(igen3Hz);
        gen1A = Convert.ToString(igen1A);
        gen2A = Convert.ToString(igen2A);
        gen3A = Convert.ToString(igen3A);

        busW = Convert.ToString((int)Math.Round(Convert.ToDouble(data["POWER_DEMAND_MW"])));
    }
}
