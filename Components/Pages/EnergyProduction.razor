    private CancellationTokenSource _cts = new();

    protected override void OnInitialized()
    {
        // Запускаем фоновую задачу без ожидания (fire-and-forget)
        _ = BackgroundLoop(_cts.Token);
        DataSetDisplay();
    }

    private async Task BackgroundLoop(CancellationToken ct)
    {
        try
        {
            while (!ct.IsCancellationRequested)
            {
                DataSetDisplay();

                // Обязательно уведомляем UI об изменениях
                await InvokeAsync(StateHasChanged);

                // Задержка, чтобы не вешать поток
                await Task.Delay(1000, ct);
            }
        }
        catch (TaskCanceledException)
        {
            // Нормальное завершение при закрытии страницы
        }
    }

    // Остановка цикла при уничтожении компонента
    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }

    public void DataSetDisplay()
    {
        var data = new Dictionary<string, string>();
        data = NuclearesGETData.Programs.Second();

        int gen1W = Convert.ToInt32(data["GENERATOR_0_KW"]);
        int gen2W = Convert.ToInt32(data["GENERATOR_1_KW"]);
        int gen3W = (int)Math.Round(Convert.ToDouble(data["GENERATOR_2_KW"]));
        int gen1RPM = Convert.ToInt32(data["STEAM_TURBINE_0_RPM"]);
        int gen2RPM = Convert.ToInt32(data["STEAM_TURBINE_1_RPM"]);
        int gen3RPM = Convert.ToInt32(data["STEAM_TURBINE_2_RPM"]);
        int gen1V = Convert.ToInt32(data["GENERATOR_0_V"]);
        int gen2V = Convert.ToInt32(data["GENERATOR_1_V"]);
        /*int gen3V = Convert.ToInt32(data["GENERATOR_2_V"]);
        int gen1Hz = Convert.ToInt32(data["GENERATOR_0_HERTZ"]);
        int gen2Hz = Convert.ToInt32(data["GENERATOR_1_HERTZ"]);
        int gen3Hz = Convert.ToInt32(data["GENERATOR_2_HERTZ"]);
        int gen1A = Convert.ToInt32(data["GENERATOR_0_A"]);
        int gen2A = Convert.ToInt32(data["GENERATOR_1_A"]);
        int gen3A = Convert.ToInt32(data["GENERATOR_2_A"]);*/
        int busW; 
        int busRPM;
        int busV;
        int busHz;
        int[] gen = new int[4];
        for (int i = 0; i < 3; i++)
        {
            int b = 1;
            gen[i] = Convert.ToInt32(gen3W.ToString().Substring(i, b));
            b++;
        }
        gen3_1W = gen[0];
        gen3_2W = gen[1];
        gen3_3W = gen[2];
        gen3_4W = gen[3];
    }
